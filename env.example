# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://statususer:password@postgres:5432/statusdb
POSTGRES_USER=statususer
POSTGRES_PASSWORD=password
POSTGRES_DB=statusdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080

# ── Public Status Page ────────────────────────────────────────────────────────
# Set to false to hide the public status page and disable /api/v1/* routes
PUBLIC_STATUS_ENABLED=true
NEXT_PUBLIC_STATUS_PAGE=true
# BACKEND_URL is set automatically in compose.yml (http://backend:8080) — no need to set here

# ── Custom Domains (optional) ─────────────────────────────────────────────────
# Feature is toggled at runtime under Settings → Custom Domains. These vars only
# affect routing/display; see docs/custom-domains-infra.md for the proxy setup.
# The host the app is normally served on. Any OTHER Host hitting "/" is treated
# as a customer custom domain and rewritten to its dedicated status page.
APP_PRIMARY_HOST=
# CNAME target shown to admins in the in-app DNS setup guide (cosmetic).
NEXT_PUBLIC_PROXY_HOST=
# Required only if running compose.custom-domains.yml (Cloudflare Tunnel).
# Get this from the Cloudflare Zero Trust dashboard when creating the tunnel.
CLOUDFLARED_TUNNEL_TOKEN=

# ── Public URL ────────────────────────────────────────────────────────────────
# Public URL of the admin dashboard (frontend), no trailing slash.
# Used for: Next.js metadataBase (APP_URL) and "view in dashboard" links in
# Discord/email alerts (FRONTEND_URL). Leave blank for local dev.
APP_URL=
FRONTEND_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_32_plus_random_bytes_here

# ── Encryption ────────────────────────────────────────────────────────────────
# Must be exactly 32 bytes (AES-256-GCM key)
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=change_me_exactly_32_bytes_here!!

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
